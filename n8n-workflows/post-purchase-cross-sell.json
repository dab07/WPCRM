    {
      "id": "guard_checks",
      "name": "Step 2 — Guard Checks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 0],
      "parameters": {
        "jsCode": "const ctx      = $('Merge Brand into Context').first().json;\nconst contacts = $('Lookup Contact').first().json;\nconst orders   = $('Lookup Order Record').first().json;\n\nconst contact = Array.isArray(contacts) && contacts.length > 0 ? contacts[0] : null;\nconst order   = Array.isArray(orders)   && orders.length   > 0 ? orders[0]   : null;\n\n// Guard 1: accepts_marketing\nif (!contact || contact.accepts_marketing !== true) {\n  return [{ json: { pass: false, reason: 'accepts_marketing is false or contact not found' } }];\n}\n\n// Guard 2: financial_status must be paid\nconst financialStatus = order?.financial_status ?? ctx.financial_status;\nif (financialStatus !== 'paid') {\n  return [{ json: { pass: false, reason: `financial_status is '${financialStatus}', not 'paid'` } }];\n}\n\n// Guard 3: cross_sell_sent_at must be null\nif (order?.cross_sell_sent_at !== null && order?.cross_sell_sent_at !== undefined) {\n  return [{ json: { pass: false, reason: 'cross_sell already sent for this order' } }];\n}\n\nreturn [{\n  json: {\n    pass:       true,\n    order_db_id: order?.id ?? null,\n    first_name:  contact?.first_name ?? 'there',\n    ...ctx\n  }\n}];"
      }
    },
