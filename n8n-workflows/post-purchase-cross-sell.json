        }
      }
    },
    {
      "id": "merge_brand",
      "name": "Merge Brand into Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0],
      "parameters": {
        "jsCode": "const order  = $('Step 1 — Extract & Enrich').first().json;\nconst brands = $input.first().json;\n\nif (!Array.isArray(brands) || brands.length === 0) {\n  throw new Error(`No brand found for shop domain: ${order.shop_domain}`);\n}\nconst brand = brands[0];\n\nreturn [{\n  json: {\n    ...order,\n    brand_id:       brand.id,\n    brand_name:     brand.name,\n    brand_category: brand.brand_category ?? 'retail',\n    email_platform: brand.email_platform ?? 'klaviyo'\n  }\n}];"
      }
    },
