        "jsCode": "const ctx         = $('Parse Claude Response').item.json;\nconst opportunity = Array.isArray($input.first().json)\n  ? $input.first().json[0]\n  : $input.first().json;\n\nif (!opportunity?.id) throw new Error('Opportunity insert did not return an id');\n\nreturn [{\n  json: {\n    ...ctx,\n    opportunity_id: opportunity.id\n  }\n}];"
