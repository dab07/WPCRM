    {
      "id": "filter_catalog",
      "name": "Filter & Build Catalog",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2420, 120],
      "parameters": {
        "jsCode": "const ctx      = $('Step 2 — Guard Checks').item.json;\nconst response = $input.first().json;\n\nconst purchasedIds = new Set((ctx.purchased_product_ids ?? []).map(String));\n\nconst catalog = (response.products ?? [])\n  .filter(p => !purchasedIds.has(String(p.id)))\n  .map(p => ({\n    title:        p.title,\n    product_type: p.product_type ?? '',\n    tags:         p.tags ?? ''\n  }));\n\nreturn [{\n  json: {\n    ...ctx,\n    catalog_json: JSON.stringify(catalog)\n  }\n}];"
      }
    },

    {
      "id": "generate_recommendations",
      "name": "Step 5 — Generate Recommendations (Claude)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [2640, 120],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type",      "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 1000,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"You are a product recommendation engine for {{ $json.brand_name }}, a {{ $json.brand_category }} brand.\\nA customer just purchased: {{ $json.purchased_titles }}.\\nHere is the brand's product catalog (excluding what was just bought): {{ $json.catalog_json }}.\\nIdentify the 3 most logical complementary products the customer would benefit from.\\nThink in terms of accessory fit and usage workflow — for example: guitar → capo, picks, strings, tuner; mosquito repellent machine → refill pack, travel size, room spray.\\nOutput JSON only — no explanation, no markdown:\\n{\\\"recommendations\\\": [{\\\"product_title\\\": string, \\\"reason\\\": string}], \\\"email_subject\\\": string, \\\"email_body_html\\\": string, \\\"sms_message\\\": string (under 160 characters)}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic_api_key",
          "name": "Anthropic API Key"
        }
      }
    },
    {
      "id": "parse_claude",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2860, 120],
      "parameters": {
        "jsCode": "const ctx      = $('Filter & Build Catalog').item.json;\nconst response = $input.first().json;\n\nlet generated;\ntry {\n  const rawText = response.content?.[0]?.text ?? '{}';\n  const cleaned = rawText.replace(/^```json\\s*/i, '').replace(/```\\s*$/i, '').trim();\n  generated = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error(`Failed to parse Claude response: ${e.message}`);\n}\n\nconst reasoningSummary = (generated.recommendations ?? [])\n  .map(r => `${r.product_title}: ${r.reason}`)\n  .join(' | ');\n\nconst firstPurchasedTitle = (ctx.line_items?.[0]?.title ?? 'your recent purchase');\n\nreturn [{\n  json: {\n    ...ctx,\n    email_subject:    generated.email_subject,\n    email_body_html:  generated.email_body_html,\n    sms_message:      generated.sms_message,\n    reasoning_summary: reasoningSummary,\n    first_purchased_title: firstPurchasedTitle\n  }\n}];"
      }
    },
