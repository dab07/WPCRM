    {
      "id": "wh_order_create",
      "name": "Shopify orders/create Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "shopify-order-create-crosssell",
      "parameters": {
        "httpMethod": "POST",
        "path": "shopify-order-create-crosssell",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "extract_enrich",
      "name": "Step 1 — Extract & Enrich",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0],
      "parameters": {
        "jsCode": "const body    = $input.first().json.body ?? $input.first().json;\nconst headers = $input.first().json.headers ?? {};\n\nconst shopDomain = headers['x-shopify-shop-domain'] ?? headers['X-Shopify-Shop-Domain'] ?? '';\nif (!shopDomain) throw new Error('Missing X-Shopify-Shop-Domain header');\nif (!body.id)    throw new Error('Missing order id in payload');\n\nconst lineItems = (body.line_items ?? []).map(i => ({\n  product_id: i.product_id,\n  variant_id: i.variant_id,\n  title:      i.title,\n  quantity:   i.quantity,\n  price:      i.price\n}));\n\nconst purchasedTitles = lineItems.map(i => i.title).join(', ');\n\nreturn [{\n  json: {\n    shop_domain:          shopDomain,\n    order_id:             String(body.id),\n    order_external_id:    String(body.id),\n    email:                body.email ?? null,\n    customer_external_id: body.customer?.id ? String(body.customer.id) : null,\n    financial_status:     body.financial_status ?? null,\n    line_items:           lineItems,\n    purchased_titles:     purchasedTitles,\n    purchased_product_ids: lineItems.map(i => i.product_id).filter(Boolean)\n  }\n}];"
      }
    },
    {
